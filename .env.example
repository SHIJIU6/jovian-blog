# Site URLs
SITE_URL=https://example.com
NEXT_PUBLIC_SITE_URL=https://example.com

# Admin access
ADMIN_ALLOWLIST=owner@example.com
BLOG_ADMIN_TOKEN=replace-with-a-long-random-token
BLOG_LOCAL_ADMIN_BYPASS=true

# AI generation
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_RESPONSES_MODEL=gpt-5

# Optional public client features
NEXT_PUBLIC_LIKE_ENDPOINT=/api/likes
NEXT_PUBLIC_SAMPLE_AUDIO=/music/GEM.mp3
BLOG_SLUG_KEY=

# Optional MCP local server settings
BLOG_BASE_URL=http://127.0.0.1:2025
BLOG_ADMIN_EMAIL=owner@example.com
